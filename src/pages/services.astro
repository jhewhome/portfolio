---
import Layout from '../layouts/Layout.astro';
import IconBadge from '../components/IconBadge.astro';
import { services, processSteps } from '../data/site';
---

<Layout title="Services" description="Freelance web development services by Jerome T. De Guzman — websites, PHP/MySQL apps, WordPress maintenance, SEO, UI implementation, and tutoring.">
  <section class="page-hero">
    <div class="container">
      <span class="section-label">Freelance</span>
      <h1>Services</h1>
      <p class="lead">
        Practical web development for professionals, small businesses, and students —
        backed by years of delivery experience and a teacher's eye for clarity.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container services-grid">
      {
        services.map((service) => (
          <article class="service-card card">
            <div class="service-card-header">
              <IconBadge name={service.icon} />
              <h2>{service.title}</h2>
            </div>
            <p>{service.description}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="process section-alt">
    <div class="container">
      <div class="section-header">
        <span class="section-label">How I work</span>
        <h2>A straightforward process</h2>
      </div>
      <ol class="process-list">
        {
          processSteps.map((step) => (
            <li>
              <IconBadge name={step.icon} size="sm" variant="soft" />
              <strong>{step.title}</strong>
              <span>{step.text}</span>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <section class="cta-band">
    <div class="container cta-inner">
      <div>
        <h2>Have a project in mind?</h2>
        <p>Tell me what you're building — I'll reply with honest feedback on scope and fit.</p>
      </div>
      <a href="/contact" class="btn btn-primary">Start a conversation</a>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    padding: clamp(2.5rem, 8vw, 4rem) 0 1rem;
  }

  .services-grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  }

  .service-card {
    padding: 1.75rem;
    transition: box-shadow 0.2s ease, transform 0.2s ease, border-color 0.2s ease;
  }

  .service-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
    border-color: rgba(124, 58, 237, 0.28);
  }

  .service-card-header {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 0.85rem;
  }

  .service-card h2 {
    font-size: 1.15rem;
    color: var(--color-navy);
    margin: 0.15rem 0 0;
    line-height: 1.35;
  }

  .service-card p {
    color: var(--color-ink-muted);
    margin: 0;
  }

  .section-alt {
    padding: 4rem 0;
    background: var(--color-surface);
    border-block: 1px solid var(--color-border);
  }

  .process-list {
    display: grid;
    gap: 1rem;
    counter-reset: step;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  @media (min-width: 700px) {
    .process-list {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .process-list li {
    counter-increment: step;
    padding: 1.5rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .process-list li::before {
    content: counter(step, decimal-leading-zero);
    position: absolute;
    top: 1rem;
    right: 1rem;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-accent);
  }

  .process-list strong {
    display: block;
    margin-bottom: 0.35rem;
    font-family: var(--font-display);
    font-size: 1.05rem;
  }

  .process-list span {
    font-size: 0.9rem;
    color: var(--color-ink-muted);
  }

  .cta-band {
    padding: 4rem 0;
    background: var(--color-navy);
    color: #e8ecf4;
  }

  .cta-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .cta-band h2 {
    color: #fff;
  }

  .cta-band p {
    color: #a8b2c8;
    max-width: 45ch;
    margin: 0;
  }

  @media (max-width: 640px) {
    .services-grid {
      grid-template-columns: 1fr;
    }

    .service-card {
      padding: 1.25rem;
    }

    .section-alt {
      padding: 3rem 0;
    }

    .cta-band {
      padding: 2.75rem 0;
    }

    .cta-inner {
      flex-direction: column;
      align-items: stretch;
    }

    .cta-inner .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
