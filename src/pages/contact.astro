---
import Layout from '../layouts/Layout.astro';
import { site, social } from '../data/site';
---

<Layout title="Contact" description="Contact Jerome De Guzman for freelance web development, part-time roles, or collaboration.">
  <section class="page-hero">
    <div class="container">
      <span class="section-label">Contact</span>
      <h1>Get in touch</h1>
      <p class="lead">
        Open to freelance projects, part-time development work, and professional opportunities.
        Send a message and I'll get back to you as soon as I can.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container contact-grid">
      <div class="contact-card card">
        <h2>Email</h2>
        <p>The best way to reach me for project inquiries and collaborations.</p>
        <a href={`mailto:${site.email}`} class="email-link">{site.email}</a>
        <p class="note">Update this address in <code>src/data/site.ts</code> with your real email.</p>
      </div>

      <div class="contact-card card">
        <h2>Online</h2>
        <ul class="link-list">
          {
            social.map((link) => (
              <li>
                <a href={link.href} target="_blank" rel="noopener noreferrer">
                  {link.label}
                </a>
              </li>
            ))
          }
          <li>
            <a href="https://ahop.jhewhome.xyz" target="_blank" rel="noopener noreferrer">
              AHOP — Graduate project
            </a>
          </li>
        </ul>
      </div>

      <div class="contact-card card availability">
        <h2>Availability</h2>
        <ul>
          {
            site.openTo.map((item) => (
              <li>
                <span class="dot" aria-hidden="true"></span>
                {item}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    padding: 4rem 0 1rem;
  }

  .contact-grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  }

  .contact-card {
    padding: 1.75rem;
  }

  .contact-card h2 {
    font-size: 1.15rem;
    color: var(--color-navy);
  }

  .contact-card p {
    color: var(--color-ink-muted);
    font-size: 0.95rem;
  }

  .email-link {
    display: inline-block;
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0.5rem 0 1rem;
    text-decoration: none;
  }

  .email-link:hover {
    text-decoration: underline;
  }

  .note {
    font-size: 0.82rem !important;
    color: var(--color-ink-subtle) !important;
    margin: 0 !important;
  }

  .note code {
    font-size: 0.8rem;
    background: var(--color-bg);
    padding: 0.1rem 0.35rem;
    border-radius: 4px;
  }

  .link-list a {
    text-decoration: none;
    font-weight: 500;
  }

  .link-list li + li {
    margin-top: 0.5rem;
  }

  .availability ul li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.95rem;
    color: var(--color-ink-muted);
    margin-bottom: 0.5rem;
  }

  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #2d9f5f;
    flex-shrink: 0;
  }
</style>
