---
import Layout from '../layouts/Layout.astro';
import SkillGroupCard from '../components/SkillGroupCard.astro';
import IconBadge from '../components/IconBadge.astro';
import { skills, site, skillIcons, timeline } from '../data/site';
---

<Layout title="About" description={`About Jerome Tuballas De Guzman — ${site.facultyRole} at PUP, MSIT student, former Senior UI/UX Developer, and full-stack web practitioner.`}>
  <section class="page-hero">
    <div class="container">
      <span class="section-label">About</span>
      <h1>Builder, teacher, and lifelong learner</h1>
      <p class="lead">
        I bring industry delivery experience into the classroom — and bring classroom clarity back into every project I build.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container about-grid">
      <div class="prose card">
        <div class="about-header">
          <img
            class="about-photo"
            src="/images/jerome-faculty.png"
            alt="Portrait photo"
            loading="lazy"
            width="280"
            height="280"
          />
          <div>
            <h2>Biography</h2>
            <p class="subtitle">{site.facultyRole} · MSIT (Data Analytics)</p>
          </div>
        </div>
        <p>
          Jerome Tuballas De Guzman is a <strong>Bachelor of Science in Computer Science</strong> graduate (2007)
          and <strong>part-time faculty member in the Computer Engineering and Information Technology Department</strong>
          at the Polytechnic University of the Philippines (PUP) Manila, Institute of Technology, where he teaches
          web development subjects including HTML, CSS, PHP, and MySQL.
        </p>
        <p>
          Before teaching, he worked as a <strong>Senior Front-End UI/UX Developer</strong> for a Korean company,
          bringing product-level design and implementation experience into his practice. He also has
          <strong>extensive BPO and freelance web development</strong> experience, delivering web-based solutions
          across different domains.
        </p>
        <p>
          He is currently pursuing a <strong>Master of Science in Information Technology (MSIT)</strong> at the
          PUP Graduate School, with a focus on strengthening his research, academic writing, and data analytics
          competencies alongside his technical expertise.
        </p>
        <p>
          A hands-on practitioner by nature, Jerome values clear code, usable interfaces, and systems that solve
          real problems — whether for students, clients, or research.
        </p>
      </div>

      <aside class="timeline card">
        <h2>Timeline</h2>
        <ul>
          {
            timeline.map((entry) => (
              <li>
                <IconBadge name={entry.icon} size="sm" variant="soft" />
                <div class="timeline-body">
                  <span class="year">{entry.year}</span>
                  <strong>{entry.title}</strong>
                  <p>{entry.text}</p>
                </div>
              </li>
            ))
          }
        </ul>
      </aside>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Technical profile</span>
        <h2>Skills & tools</h2>
      </div>
      <div class="skills-grid">
        {
          Object.entries(skills).map(([group, items]) => (
            <SkillGroupCard group={group} items={items} icon={skillIcons[group] ?? 'tools'} />
          ))
        }
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    padding: clamp(2.5rem, 8vw, 4rem) 0 1rem;
  }

  .about-grid {
    display: grid;
    gap: 1.5rem;
  }

  @media (min-width: 900px) {
    .about-grid {
      grid-template-columns: 1.5fr 1fr;
    }
  }

  .prose,
  .timeline {
    padding: 2rem;
  }

  .about-header {
    display: grid;
    gap: 1.25rem;
    align-items: center;
    margin-bottom: 1.5rem;
  }

  @media (min-width: 640px) {
    .about-header {
      grid-template-columns: 140px 1fr;
    }
  }

  .about-photo {
    width: 140px;
    height: 140px;
    border-radius: 18px;
    object-fit: cover;
    object-position: 50% 15%;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
    background: var(--color-bg);
  }

  .subtitle {
    margin: 0.25rem 0 0;
    color: var(--color-ink-muted);
    font-size: 0.95rem;
  }

  .prose p {
    color: var(--color-ink-muted);
  }

  .timeline ul {
    display: grid;
    gap: 1.25rem;
  }

  .timeline li {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1rem;
    align-items: start;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--color-border);
  }

  .timeline li:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .timeline-body {
    min-width: 0;
  }

  .year {
    display: block;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.25rem;
  }

  .timeline p {
    font-size: 0.9rem;
    color: var(--color-ink-muted);
    margin: 0.25rem 0 0;
  }

  .section-alt {
    background: var(--color-surface);
    border-block: 1px solid var(--color-border);
  }

  .skills-grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  }

  @media (max-width: 640px) {
    .prose,
    .timeline {
      padding: 1.25rem;
    }

    .about-header {
      grid-template-columns: 1fr;
      text-align: center;
      justify-items: center;
    }

    .about-photo {
      width: 120px;
      height: 120px;
    }

    .timeline li {
      grid-template-columns: 1fr;
      gap: 0.35rem;
    }

    .skills-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
