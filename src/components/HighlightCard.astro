---
import IconBadge from './IconBadge.astro';

interface Props {
  label: string;
  text: string;
  icon: string;
}

const { label, text, icon } = Astro.props;
---

<div class="highlight-card card reveal-item">
  <div class="highlight-top">
    <IconBadge name={icon} size="sm" variant="soft" />
    <p class="highlight-label">{label}</p>
  </div>
  <p class="highlight-text">{text}</p>
</div>

<style>
  .highlight-card {
    padding: 1.25rem 1.35rem;
  }

  .highlight-top {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    margin-bottom: 0.65rem;
  }

  .highlight-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0;
  }

  .highlight-text {
    font-size: 0.95rem;
    color: var(--color-ink);
    margin: 0;
    line-height: 1.5;
  }
</style>
