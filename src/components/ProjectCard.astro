---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<article class="project-card card">
  <div class="card-top">
    <div class="tags">
      {project.tags.map((tag) => (
        <span class="tag">{tag}</span>
      ))}
      <span class:list={['tag', 'status', project.status === 'Live' && 'status-live']}>
        {project.status}
      </span>
    </div>
    <h3>{project.title}</h3>
    <p>{project.summary}</p>
  </div>

  <div class="stack">
    {project.stack.map((tech) => (
      <span>{tech}</span>
    ))}
  </div>

  <div class="card-actions">
    <a href={`/projects#${project.slug}`} class="btn btn-ghost">Details</a>
    {project.href && (
      <a href={project.href} class="btn btn-primary" target="_blank" rel="noopener noreferrer">
        Live demo
      </a>
    )}
  </div>
</article>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .project-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .card-top {
    flex: 1;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1rem;
  }

  .status {
    background: #eef0f3;
    color: var(--color-ink-muted);
  }

  .status-live {
    background: #e8f5ee;
    color: #1f6b45;
  }

  .project-card h3 {
    margin-bottom: 0.5rem;
  }

  .project-card p {
    color: var(--color-ink-muted);
    font-size: 0.95rem;
  }

  .stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 1.25rem 0;
  }

  .stack span {
    font-size: 0.78rem;
    padding: 0.2rem 0.55rem;
    border-radius: 6px;
    background: var(--color-bg);
    color: var(--color-ink-muted);
    border: 1px solid var(--color-border);
  }

  .card-actions {
    display: flex;
    gap: 0.65rem;
    flex-wrap: wrap;
    margin-top: auto;
  }

  .card-actions .btn {
    font-size: 0.85rem;
    padding: 0.6rem 1rem;
  }
</style>
