---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<article class="project-card card">
  <div class="card-top">
    <div class="tags">
      {project.tags.map((tag) => (
        <span class="tag">{tag}</span>
      ))}
      <span
        class:list={[
          'tag',
          'status',
          project.status === 'Live' && 'status-live',
          project.status === 'Prototype' && 'status-prototype',
        ]}
      >
        {project.status}
      </span>
    </div>
    <h3>{project.title}</h3>
    <p>{project.summary}</p>
  </div>

  <div class="stack">
    {project.stack.map((tech) => (
      <span>{tech}</span>
    ))}
  </div>

  <div class="card-actions">
    <a href={`/projects#${project.slug}`} class="btn btn-ghost">Details</a>
    {project.href && (
      <a href={project.href} class="btn btn-primary" target="_blank" rel="noopener noreferrer">
        Live demo
      </a>
    )}
    {project.github && (
      <a href={project.github} class="btn btn-secondary" target="_blank" rel="noopener noreferrer">
        GitHub
      </a>
    )}
  </div>
</article>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    position: relative;
    overflow: hidden;
    transition: box-shadow 0.2s ease, transform 0.2s ease, border-color 0.2s ease;
  }

  .project-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(800px 240px at 20% 0%, rgba(124, 58, 237, 0.14), transparent 55%),
      radial-gradient(700px 220px at 90% 30%, rgba(6, 182, 212, 0.12), transparent 60%);
    opacity: 0;
    transition: opacity 0.2s ease;
    pointer-events: none;
  }

  .project-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
    border-color: rgba(124, 58, 237, 0.28);
  }

  .project-card:hover::before {
    opacity: 1;
  }

  .card-top {
    flex: 1;
    position: relative;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1rem;
  }

  .status {
    background: rgba(15, 23, 42, 0.06);
    color: var(--color-ink-muted);
  }

  .status-live {
    background: rgba(16, 185, 129, 0.12);
    color: #047857;
  }

  .status-prototype {
    background: rgba(245, 158, 11, 0.14);
    color: #b45309;
  }

  .project-card h3 {
    margin-bottom: 0.5rem;
  }

  .project-card p {
    color: var(--color-ink-muted);
    font-size: 0.95rem;
  }

  .stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 1.25rem 0;
  }

  .stack span {
    font-size: 0.78rem;
    padding: 0.2rem 0.55rem;
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.72);
    color: var(--color-ink-muted);
    border: 1px solid var(--color-border);
  }

  .card-actions {
    display: flex;
    gap: 0.65rem;
    flex-wrap: wrap;
    margin-top: auto;
  }

  .card-actions .btn {
    font-size: 0.85rem;
    padding: 0.6rem 1rem;
  }
</style>
